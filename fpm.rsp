@pretiffy
option --version
system codee format ./src
system fortitute check ./src --fix

@clean
option clean --all

@rebuild
option clean --all
option build

@build
option build

@test
options test 

@doc
option --version
system cd ./.dox & doxygen ./Doxyfile.in & cd ..
system powershell ./tools/Fix-Doxygen.ps1 -Path "./docs"